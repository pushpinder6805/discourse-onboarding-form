<div class="questionnaire-page-container">
  <div class="questionnaire-card">

    {{#if this.hasQuestionnaire}}
      <div class="questionnaire-header">
        <div class="questionnaire-logo">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="20" fill="#2563eb"/>
            <path d="M13 20l5 5 9-10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h1 class="questionnaire-title">{{this.questionnaire.name}}</h1>
        {{#if this.questionnaire.description}}
          <p class="questionnaire-description">{{this.questionnaire.description}}</p>
        {{/if}}
      </div>

      <div class="questionnaire-fields">
        {{#each this.fields as |field|}}
          <div class="qfield qfield-{{field.type}} {{if field.required "required"}}">

            {{#if (or (eq field.type "text") (eq field.type "phone") (eq field.type "number"))}}
              <label class="qfield-label">
                {{field.label}}
                {{#if field.required}}<span class="required-star">*</span>{{/if}}
              </label>
              <input
                type={{if (eq field.type "phone") "tel" (if (eq field.type "number") "number" "text")}}
                class="qfield-input"
                value={{get this.fieldValues field.id}}
                placeholder={{field.placeholder}}
                {{on "input" (fn this.updateField field.id)}}
              />
            {{/if}}

            {{#if (eq field.type "textarea")}}
              <label class="qfield-label">
                {{field.label}}
                {{#if field.required}}<span class="required-star">*</span>{{/if}}
              </label>
              <textarea
                class="qfield-textarea"
                placeholder={{field.placeholder}}
                {{on "input" (fn this.updateField field.id)}}
              >{{get this.fieldValues field.id}}</textarea>
            {{/if}}

            {{#if (eq field.type "terms_and_conditions")}}
              <div class="qfield-terms-block">
                <label class="qfield-label">
                  {{field.label}}
                  {{#if field.required}}<span class="required-star">*</span>{{/if}}
                </label>
                <div
                  class="qfield-terms-scroll"
                  {{on "scroll" (fn this.markScrolled field.id)}}
                >
                  <p>{{field.content}}</p>
                </div>
                <label class="qfield-acceptance-row">
                  <input
                    type="checkbox"
                    class="qfield-checkbox"
                    checked={{get this.fieldValues field.id}}
                    {{on "change" (fn this.updateField field.id)}}
                  />
                  <span class="qfield-acceptance-text">
                    I have read and agree to these terms
                  </span>
                </label>
              </div>
            {{/if}}

            {{#if (eq field.type "acceptance")}}
              <div class="qfield-acceptance-block">
                {{#if field.content}}
                  <div class="qfield-terms-scroll">
                    <p>{{field.content}}</p>
                  </div>
                {{/if}}
                <label class="qfield-acceptance-row">
                  <input
                    type="checkbox"
                    class="qfield-checkbox"
                    checked={{get this.fieldValues field.id}}
                    {{on "change" (fn this.updateField field.id)}}
                  />
                  <span class="qfield-acceptance-text">
                    {{field.label}}
                    {{#if field.required}}<span class="required-star">*</span>{{/if}}
                  </span>
                </label>
              </div>
            {{/if}}

            {{#if (eq field.type "checkbox")}}
              <label class="qfield-checkbox-row">
                <input
                  type="checkbox"
                  class="qfield-checkbox"
                  checked={{get this.fieldValues field.id}}
                  {{on "change" (fn this.updateField field.id)}}
                />
                <span class="qfield-checkbox-text">
                  {{#if field.content}}{{field.content}}{{else}}{{field.label}}{{/if}}
                  {{#if field.required}}<span class="required-star">*</span>{{/if}}
                </span>
              </label>
            {{/if}}

          </div>
        {{/each}}
      </div>

      <div class="questionnaire-actions">
        <button
          type="button"
          class="btn btn-primary questionnaire-submit-btn"
          disabled={{or (not this.canSubmit) this.isSubmitting}}
          {{on "click" this.submitForm}}
        >
          {{#if this.isSubmitting}}
            Submitting...
          {{else}}
            Submit
          {{/if}}
        </button>
      </div>

    {{else}}
      <div class="questionnaire-no-content">
        <p>No questionnaire is currently available. You will be redirected to the home page.</p>
      </div>
    {{/if}}

  </div>
</div>
